# ---- backend selection ----
STORE=auto                 # auto | postgres | memory
DATABASE_URL=postgresql://rag:rag@localhost:5432/ragdemo

# ---- LLM: answer generation (chat) ----
# Groq is OpenAI-compatible for CHAT only (it has no embeddings endpoint).
LLM_PROVIDER=auto          # auto | openai | groq | none
GROQ_API_KEY=              # set this to generate answers with Groq (fast, cheap)
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=            # optional: needed only for OpenAI chat AND/OR embeddings
CHAT_MODEL=gpt-4o-mini     # used when LLM_PROVIDER=openai

# ---- embeddings (retrieval) ----
# auto: openai (if OPENAI_API_KEY) -> fastembed (free local model) -> hashing.
# For good retrieval with only a Groq key, use fastembed (no API cost).
EMBED_PROVIDER=auto        # auto | openai | fastembed | hashing
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536             # openai=1536, fastembed=384 (set to 384 for pgvector + fastembed)

# ---- api ----
API_KEY=                   # if set, required as X-API-Key on /ingest and eval-run
CORS_ORIGINS=*
