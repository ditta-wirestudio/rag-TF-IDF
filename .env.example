# NOTE: comments live on their own lines — some parsers (docker compose)
# treat inline comments as part of the value.

# ---- backend selection ----
# STORE: auto | postgres | memory
STORE=auto
DATABASE_URL=postgresql://rag:rag@localhost:5432/ragdemo

# ---- LLM: answer generation (chat) ----
# Groq is OpenAI-compatible for CHAT only (it has no embeddings endpoint).
# LLM_PROVIDER: auto | openai | groq | none
LLM_PROVIDER=auto
# Set GROQ_API_KEY to generate answers with Groq (fast, cheap)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY is optional: needed only for OpenAI chat AND/OR embeddings
OPENAI_API_KEY=
# CHAT_MODEL is used when LLM_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini

# ---- embeddings (retrieval) ----
# auto: openai (if OPENAI_API_KEY) -> fastembed (free local model) -> hashing.
# For good retrieval with only a Groq key, use fastembed (no API cost).
# EMBED_PROVIDER: auto | openai | fastembed | hashing
EMBED_PROVIDER=auto
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_MODEL=text-embedding-3-small
# EMBED_DIM: openai=1536, fastembed=384 (set to 384 for pgvector + fastembed)
EMBED_DIM=1536

# ---- api ----
# API_KEY: if set, required as X-API-Key on /ingest and eval-run
API_KEY=
CORS_ORIGINS=*
